---
---

<section class="commissioni" id="commissioni" aria-labelledby="commissioni-title">
  <div class="container">
    <div class="section-intro reveal">
      <span class="section-label">Zero Commissioni</span>
      <h2 id="commissioni-title">Ogni ordine su una piattaforma delivery ti costa fino al <em>35%</em>.</h2>
      <p>Le piattaforme trattengono il 30–35% su ogni ordine (dati FIPE). Non perdi solo margine: perdi il contatto diretto con il cliente. Con FoodBot paghi una tariffa fissa, <strong>senza commissioni. Mai.</strong></p>
    </div>

    <!-- Receipt Comparison -->
    <div class="commissioni__comparison">

      <!-- Delivery Platform Receipt -->
      <div class="commissioni__receipt commissioni__receipt--delivery reveal reveal-delay-1">
        <div class="commissioni__receipt-header commissioni__receipt-header--delivery">
          <span class="commissioni__receipt-icon">📱</span>
          <span class="commissioni__receipt-brand">Piattaforma Delivery</span>
        </div>
        <div class="commissioni__receipt-body">
          <div class="commissioni__receipt-row">
            <span>1x Pizza Margherita</span>
            <span>&euro;10,00</span>
          </div>
          <div class="commissioni__receipt-divider"></div>
          <div class="commissioni__receipt-row commissioni__receipt-row--commission">
            <span>Commissione piattaforma (35%)</span>
            <span class="commissioni__amount--negative">&minus;&euro;3,50</span>
          </div>
          <div class="commissioni__receipt-divider"></div>
          <div class="commissioni__receipt-row commissioni__receipt-row--total">
            <span>Il tuo incasso reale</span>
            <span class="commissioni__amount--negative">&euro;6,50</span>
          </div>
        </div>
        <div class="commissioni__receipt-footer commissioni__receipt-footer--delivery">
          <span>Perdi <strong>&euro;3,50</strong> ad ogni ordine</span>
          <span class="commissioni__receipt-verdict commissioni__receipt-verdict--bad">Zero relazione col cliente</span>
        </div>
      </div>

      <!-- VS Badge -->
      <div class="commissioni__vs reveal reveal-delay-2">
        <span>VS</span>
      </div>

      <!-- FoodBot Receipt -->
      <div class="commissioni__receipt commissioni__receipt--foodbot reveal reveal-delay-3">
        <div class="commissioni__receipt-header commissioni__receipt-header--foodbot">
          <span class="commissioni__receipt-icon">🤖</span>
          <span class="commissioni__receipt-brand">FoodBot</span>
        </div>
        <div class="commissioni__receipt-body">
          <div class="commissioni__receipt-row">
            <span>1x Pizza Margherita</span>
            <span>&euro;10,00</span>
          </div>
          <div class="commissioni__receipt-divider"></div>
          <div class="commissioni__receipt-row commissioni__receipt-row--commission">
            <span>Commissione FoodBot</span>
            <span class="commissioni__amount--positive">&euro;0,00</span>
          </div>
          <div class="commissioni__receipt-divider"></div>
          <div class="commissioni__receipt-row commissioni__receipt-row--total">
            <span>Il tuo incasso reale</span>
            <span class="commissioni__amount--positive">&euro;10,00</span>
          </div>
        </div>
        <div class="commissioni__receipt-footer commissioni__receipt-footer--foodbot">
          <span>Incassi <strong>il 100%</strong> di ogni ordine</span>
          <span class="commissioni__receipt-verdict commissioni__receipt-verdict--good">Relazione diretta col cliente</span>
        </div>
      </div>
    </div>

    <!-- Savings Calculator -->
    <div class="commissioni__savings reveal reveal-delay-4">
      <div class="commissioni__savings-inner">
        <h3 class="commissioni__savings-title">Quanto risparmi spostando gli ordini su FoodBot?</h3>
        <p class="commissioni__savings-subtitle">Anche solo 10 ordini al giorno recuperati dal delivery</p>

        <div class="commissioni__savings-grid">
          <div class="commissioni__savings-card commissioni__savings-card--lost">
            <span class="commissioni__savings-label">Perso in commissioni / mese</span>
            <span class="commissioni__savings-value commissioni__savings-value--negative" data-target="1050" data-prefix="-&euro;">
              -&euro;0
            </span>
            <span class="commissioni__savings-detail">10 ordini/giorno &times; &euro;3,50 &times; 30 giorni</span>
          </div>

          <div class="commissioni__savings-card commissioni__savings-card--cost">
            <span class="commissioni__savings-label">Costo FoodBot / mese</span>
            <span class="commissioni__savings-value commissioni__savings-value--neutral">
              &euro;29,90
            </span>
            <span class="commissioni__savings-detail">Tariffa fissa, zero sorprese</span>
          </div>

          <div class="commissioni__savings-card commissioni__savings-card--saved">
            <span class="commissioni__savings-label">Risparmio netto / mese</span>
            <span class="commissioni__savings-value commissioni__savings-value--positive" data-target="1020" data-prefix="+&euro;">
              +&euro;0
            </span>
            <span class="commissioni__savings-detail">Soldi che tornano nel tuo cassetto</span>
          </div>
        </div>

        <p class="commissioni__savings-note">
          Stima basata su ordine medio di &euro;10 e commissione piattaforma del 35% (fonte: FIPE — Federazione Italiana Pubblici Esercizi).
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  function animateCounters() {
    const counters = document.querySelectorAll('[data-target]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0', 10);
        const prefix = el.dataset.prefix || '';
        const duration = 2000;
        const start = performance.now();

        function step(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          // ease-out cubic
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(eased * target);
          el.textContent = `${prefix}${current.toLocaleString('it-IT')}`;
          if (progress < 1) {
            requestAnimationFrame(step);
          }
        }

        requestAnimationFrame(step);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach((counter) => observer.observe(counter));
  }

  document.addEventListener('DOMContentLoaded', animateCounters);
  document.addEventListener('astro:page-load', animateCounters);
</script>

<style>
  .commissioni {
    background: linear-gradient(180deg, #ffffff 0%, #f5f7fa 100%);
    position: relative;
    overflow: hidden;
  }

  .commissioni::before {
    content: '';
    position: absolute;
    top: -250px;
    right: -200px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 107, 53, 0.04), transparent 70%);
    pointer-events: none;
  }

  .commissioni::after {
    content: '';
    position: absolute;
    bottom: -200px;
    left: -150px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(78, 205, 196, 0.04), transparent 70%);
    pointer-events: none;
  }

  .commissioni h2 em {
    font-style: normal;
    color: var(--orange);
    position: relative;
  }

  .commissioni h2 em::after {
    content: '';
    position: absolute;
    bottom: 0px;
    left: -4px;
    width: calc(100% + 8px);
    height: 10px;
    background: linear-gradient(90deg, rgba(255, 107, 53, 0.18), rgba(255, 107, 53, 0.08));
    border-radius: 5px;
    z-index: -1;
  }

  /* ── Comparison Layout ── */
  .commissioni__comparison {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-lg);
    align-items: center;
    margin-bottom: var(--space-2xl);
  }

  /* ── VS Badge ── */
  .commissioni__vs {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-full);
    background: var(--deep-dark);
    color: var(--white);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 0.05em;
    box-shadow: 0 8px 24px rgba(13, 27, 42, 0.25);
    flex-shrink: 0;
  }

  /* ── Receipt Card ── */
  .commissioni__receipt {
    border-radius: 24px;
    overflow: hidden;
    border: 1.5px solid transparent;
    transition: all 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .commissioni__receipt:hover {
    transform: translateY(-6px) scale(1.01);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08), 0 8px 20px rgba(0, 0, 0, 0.04);
  }

  .commissioni__receipt--delivery {
    background: var(--pastel-rose);
    border-color: rgba(220, 53, 69, 0.12);
  }

  .commissioni__receipt--delivery:hover {
    border-color: rgba(220, 53, 69, 0.25);
  }

  .commissioni__receipt--foodbot {
    background: var(--pastel-green);
    border-color: rgba(45, 139, 78, 0.12);
  }

  .commissioni__receipt--foodbot:hover {
    border-color: rgba(45, 139, 78, 0.25);
  }

  /* ── Receipt Header ── */
  .commissioni__receipt-header {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-lg);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .commissioni__receipt-header--delivery {
    background: rgba(220, 53, 69, 0.08);
    color: #b02a37;
  }

  .commissioni__receipt-header--foodbot {
    background: rgba(45, 139, 78, 0.08);
    color: #1a7d3e;
  }

  .commissioni__receipt-icon {
    font-size: 1.5rem;
  }

  /* ── Receipt Body ── */
  .commissioni__receipt-body {
    padding: var(--space-lg);
  }

  .commissioni__receipt-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--gray-700);
    padding: var(--space-xs) 0;
  }

  .commissioni__receipt-row--commission {
    font-weight: 600;
  }

  .commissioni__receipt-row--total {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--dark);
    padding-top: var(--space-sm);
  }

  .commissioni__receipt-divider {
    height: 1px;
    background: repeating-linear-gradient(
      90deg,
      var(--gray-300) 0px,
      var(--gray-300) 4px,
      transparent 4px,
      transparent 8px
    );
    margin: var(--space-xs) 0;
  }

  .commissioni__amount--negative {
    color: #dc3545;
    font-weight: 700;
  }

  .commissioni__amount--positive {
    color: #1a7d3e;
    font-weight: 700;
  }

  /* ── Receipt Footer ── */
  .commissioni__receipt-footer {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: var(--space-md) var(--space-lg);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .commissioni__receipt-footer--delivery {
    background: rgba(220, 53, 69, 0.05);
    color: #b02a37;
  }

  .commissioni__receipt-footer--foodbot {
    background: rgba(45, 139, 78, 0.05);
    color: #1a7d3e;
  }

  .commissioni__receipt-verdict {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .commissioni__receipt-verdict--bad::before {
    content: '\2716';
    color: #dc3545;
  }

  .commissioni__receipt-verdict--good::before {
    content: '\2714';
    color: #1a7d3e;
  }

  /* ── Savings Calculator ── */
  .commissioni__savings {
    position: relative;
  }

  .commissioni__savings-inner {
    background: var(--white);
    border: 1.5px solid rgba(0, 0, 0, 0.06);
    border-radius: 24px;
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }

  .commissioni__savings-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--dark);
    margin-bottom: var(--space-xs);
  }

  .commissioni__savings-subtitle {
    font-size: 1rem;
    color: var(--gray-500);
    margin-bottom: var(--space-lg);
  }

  .commissioni__savings-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .commissioni__savings-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-lg) var(--space-md);
    border-radius: 20px;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .commissioni__savings-card:hover {
    transform: translateY(-4px);
  }

  .commissioni__savings-card--lost {
    background: var(--pastel-rose);
  }

  .commissioni__savings-card--cost {
    background: var(--pastel-cream);
  }

  .commissioni__savings-card--saved {
    background: var(--pastel-green);
  }

  .commissioni__savings-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--gray-700);
  }

  .commissioni__savings-value {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2.4rem;
    line-height: 1.1;
  }

  .commissioni__savings-value--negative {
    color: #dc3545;
  }

  .commissioni__savings-value--neutral {
    color: var(--blue);
  }

  .commissioni__savings-value--positive {
    color: #1a7d3e;
  }

  .commissioni__savings-detail {
    font-size: 0.85rem;
    color: var(--gray-500);
    line-height: 1.5;
  }

  .commissioni__savings-note {
    font-size: 0.78rem;
    color: var(--gray-500);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
    font-style: italic;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .commissioni__comparison {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .commissioni__vs {
      width: 44px;
      height: 44px;
      font-size: 0.85rem;
      margin: 0 auto;
    }

    .commissioni__savings-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .commissioni__savings-value {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .commissioni__receipt-body {
      padding: var(--space-md);
    }

    .commissioni__receipt-row {
      font-size: 0.88rem;
    }

    .commissioni__receipt-row--total {
      font-size: 1rem;
    }
  }
</style>
