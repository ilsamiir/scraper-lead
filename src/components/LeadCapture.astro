---
---
<section class="lead" id="lead">
  <div class="lead__bg-pattern" aria-hidden="true"></div>
  <div class="lead__glow lead__glow--1" aria-hidden="true"></div>
  <div class="lead__glow lead__glow--2" aria-hidden="true"></div>
  <div class="lead__glow lead__glow--3" aria-hidden="true"></div>

  <div class="container">
    <div class="lead__wrapper reveal">

      <!-- Left: Copy & Benefits -->
      <div class="lead__content">
        <span class="lead__badge">
          <span class="lead__badge-dot"></span>
          Posti limitati — Offerta riservata
        </span>

        <h2 class="lead__title">
          Smetti di regalare margini<br/>
          alle piattaforme di delivery.
          <span class="lead__title-highlight">Inizia oggi.</span>
        </h2>

        <p class="lead__subtitle">
          Unisciti a <strong>500+ pizzerie al taglio</strong> che hanno già eliminato le commissioni
          e aumentato i margini fino al <strong>30%</strong>. Ricevi la tua demo personalizzata
          e scopri quanto puoi risparmiare ogni mese.
        </p>

        <!-- Stats row -->
        <div class="lead__stats">
          <div class="lead__stat">
            <span class="lead__stat-number">0%</span>
            <span class="lead__stat-label">Commissioni</span>
          </div>
          <div class="lead__stat-divider"></div>
          <div class="lead__stat">
            <span class="lead__stat-number">5 min</span>
            <span class="lead__stat-label">Attivazione</span>
          </div>
          <div class="lead__stat-divider"></div>
          <div class="lead__stat">
            <span class="lead__stat-number">30 gg</span>
            <span class="lead__stat-label">Prova gratuita</span>
          </div>
        </div>

        <!-- Trust elements -->
        <div class="lead__trust">
          <div class="lead__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4ECDC4" stroke-width="2.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            Nessuna carta di credito richiesta
          </div>
          <div class="lead__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4ECDC4" stroke-width="2.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            Disdici quando vuoi, senza vincoli
          </div>
          <div class="lead__trust-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4ECDC4" stroke-width="2.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            Supporto dedicato via WhatsApp
          </div>
        </div>
      </div>

      <!-- Right: Form Card -->
      <div class="lead__form-card">
        <div class="lead__form-header">
          <span class="lead__form-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF6B35" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="m8 12 3 3 5-6"/></svg>
          </span>
          <h3>Richiedi la tua demo gratuita</h3>
          <p>Compila il form e ti ricontattiamo entro 24 ore</p>
        </div>

        <form class="lead__form" id="leadForm" action="mailto:info@ristobot.it" method="post" enctype="text/plain">
          <div class="lead__field">
            <label for="lead-name">Il tuo nome</label>
            <input type="text" id="lead-name" name="nome" placeholder="es. Marco Rossi" required />
          </div>

          <div class="lead__field">
            <label for="lead-email">Email</label>
            <input type="email" id="lead-email" name="email" placeholder="es. marco@pizzeria.it" required />
          </div>

          <div class="lead__field">
            <label for="lead-phone">Telefono / WhatsApp</label>
            <input type="tel" id="lead-phone" name="telefono" placeholder="es. 333 123 4567" />
          </div>

          <div class="lead__field">
            <label for="lead-city">Città della pizzeria</label>
            <input type="text" id="lead-city" name="citta" placeholder="es. Roma, Milano, Napoli..." />
          </div>

          <!-- Primary CTA -->
          <button type="submit" class="lead__btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4z"/></svg>
            Iscriviti Adesso
          </button>

          <!-- Secondary CTA -->
          <a href="mailto:info@ristobot.it?subject=Richiesta%20informazioni%20FoodBot&body=Ciao,%20vorrei%20maggiori%20informazioni%20su%20FoodBot." class="lead__btn-secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Contattaci Ora
          </a>
        </form>

        <p class="lead__form-privacy">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          I tuoi dati sono al sicuro. Niente spam, lo promettiamo.
        </p>
      </div>
    </div>

    <!-- Bottom social proof bar -->
    <div class="lead__proof reveal">
      <div class="lead__proof-item">
        <div class="lead__proof-stars">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#FF6B35" stroke="none"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#FF6B35" stroke="none"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#FF6B35" stroke="none"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#FF6B35" stroke="none"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#FF6B35" stroke="none"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/></svg>
        </div>
        <span><strong>4.8/5</strong> da 200+ recensioni</span>
      </div>
      <div class="lead__proof-divider"></div>
      <div class="lead__proof-item">
        <span class="lead__proof-number">500+</span>
        <span>Pizzerie attive in tutta Italia</span>
      </div>
      <div class="lead__proof-divider"></div>
      <div class="lead__proof-item">
        <span class="lead__proof-number">+34%</span>
        <span>Aumento medio prenotazioni</span>
      </div>
    </div>
  </div>
</section>

<style>
  .lead {
    position: relative;
    background: linear-gradient(165deg, #0D1B2A 0%, #0A3D62 45%, #0D1B2A 100%);
    padding: var(--space-3xl) 0 var(--space-2xl);
    overflow: hidden;
  }

  .lead__bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(255,107,53,0.04) 0%, transparent 50%),
      radial-gradient(circle at 80% 30%, rgba(78,205,196,0.04) 0%, transparent 50%);
    pointer-events: none;
  }

  .lead__glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(120px);
  }

  .lead__glow--1 {
    width: 500px;
    height: 500px;
    top: -200px;
    left: -150px;
    background: rgba(255,107,53,0.12);
    animation: glowFloat 8s ease-in-out infinite;
  }

  .lead__glow--2 {
    width: 400px;
    height: 400px;
    bottom: -150px;
    right: -100px;
    background: rgba(78,205,196,0.08);
    animation: glowFloat 10s ease-in-out infinite reverse;
  }

  .lead__glow--3 {
    width: 300px;
    height: 300px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(255,107,53,0.05);
    animation: glowPulse 6s ease-in-out infinite;
  }

  @keyframes glowFloat {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -20px); }
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
  }

  .lead__wrapper {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-2xl);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── Badge ── */
  .lead__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background: rgba(255,107,53,0.12);
    border: 1px solid rgba(255,107,53,0.25);
    border-radius: var(--radius-full);
    font-size: 0.82rem;
    font-weight: 700;
    color: #FF6B35;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-md);
  }

  .lead__badge-dot {
    width: 8px;
    height: 8px;
    background: #FF6B35;
    border-radius: 50%;
    animation: dotPulse 2s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(255,107,53,0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(255,107,53,0); }
  }

  /* ── Title ── */
  .lead__title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 900;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: var(--space-md);
    letter-spacing: -0.02em;
  }

  .lead__title-highlight {
    color: #FF6B35;
    display: block;
    position: relative;
  }

  /* ── Subtitle ── */
  .lead__subtitle {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.75;
    margin-bottom: var(--space-lg);
    max-width: 520px;
  }

  .lead__subtitle strong {
    color: rgba(255,255,255,0.95);
    font-weight: 700;
  }

  /* ── Stats ── */
  .lead__stats {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
    padding: var(--space-sm) 0;
  }

  .lead__stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .lead__stat-number {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 900;
    color: #FF6B35;
  }

  .lead__stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .lead__stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.12);
  }

  /* ── Trust ── */
  .lead__trust {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .lead__trust-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
  }

  /* ── Form Card ── */
  .lead__form-card {
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.06);
    position: relative;
  }

  .lead__form-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #FF6B35, #4ECDC4);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .lead__form-header {
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .lead__form-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    background: rgba(255,107,53,0.1);
    border: 1px solid rgba(255,107,53,0.2);
    border-radius: 50%;
    margin-bottom: 0.75rem;
  }

  .lead__form-header h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 0.35rem;
  }

  .lead__form-header p {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.5);
  }

  /* ── Form fields ── */
  .lead__form {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .lead__field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .lead__field label {
    font-size: 0.78rem;
    font-weight: 700;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .lead__field input {
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.06);
    border: 1.5px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: all 0.25s ease;
    outline: none;
  }

  .lead__field input::placeholder {
    color: rgba(255,255,255,0.25);
  }

  .lead__field input:focus {
    border-color: #FF6B35;
    background: rgba(255,107,53,0.06);
    box-shadow: 0 0 0 3px rgba(255,107,53,0.1);
  }

  /* ── Buttons ── */
  .lead__btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.95rem 1.5rem;
    background: linear-gradient(135deg, #FF6B35, #E55A25);
    color: var(--white);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    border: none;
    border-radius: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(255,107,53,0.35);
    margin-top: 0.4rem;
    position: relative;
    overflow: hidden;
  }

  .lead__btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: left 0.6s ease;
  }

  .lead__btn-primary:hover::before {
    left: 100%;
  }

  .lead__btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(255,107,53,0.45);
  }

  .lead__btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: transparent;
    color: rgba(255,255,255,0.85);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    text-align: center;
  }

  .lead__btn-secondary:hover {
    border-color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.05);
    transform: translateY(-1px);
    color: var(--white);
  }

  /* ── Privacy note ── */
  .lead__form-privacy {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.8rem;
    font-size: 0.76rem;
    color: rgba(255,255,255,0.3);
    text-align: center;
  }

  /* ── Social proof bar ── */
  .lead__proof {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-top: var(--space-2xl);
    padding: var(--space-md) var(--space-lg);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-lg);
    position: relative;
    z-index: 1;
  }

  .lead__proof-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.65);
  }

  .lead__proof-item strong {
    color: var(--white);
    font-weight: 800;
  }

  .lead__proof-stars {
    display: flex;
    gap: 2px;
  }

  .lead__proof-number {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.2rem;
    color: #FF6B35;
  }

  .lead__proof-divider {
    width: 1px;
    height: 30px;
    background: rgba(255,255,255,0.1);
  }

  /* ── Responsive ── */
  @media (max-width: 968px) {
    .lead__wrapper {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .lead__content {
      text-align: center;
    }

    .lead__subtitle {
      max-width: 100%;
    }

    .lead__stats {
      justify-content: center;
    }

    .lead__trust {
      align-items: center;
    }
  }

  @media (max-width: 768px) {
    .lead {
      padding: var(--space-2xl) 0 var(--space-xl);
    }

    .lead__stats {
      flex-wrap: wrap;
      gap: var(--space-sm);
    }

    .lead__stat-divider {
      display: none;
    }

    .lead__proof {
      flex-direction: column;
      gap: var(--space-sm);
      text-align: center;
    }

    .lead__proof-divider {
      width: 60px;
      height: 1px;
    }

    .lead__proof-item {
      flex-direction: column;
      gap: 0.25rem;
    }

    .lead__form-card {
      padding: var(--space-md);
    }
  }
</style>
