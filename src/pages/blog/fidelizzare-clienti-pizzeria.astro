    color: var(--white);
    margin-bottom: var(--space-md);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .article-hero__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 500;
  }

