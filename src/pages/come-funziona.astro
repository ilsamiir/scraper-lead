---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const clientSteps = [
  {
    num: '1',
    emoji: '📱',
    title: 'Sceglie dal menu digitale',
    description: 'Il cliente apre il menu digitale della tua pizzeria al taglio dal proprio smartphone. Nessuna app da scaricare, funziona direttamente dal browser.',
  },
  {
    num: '2',
    emoji: '🛒',
    title: 'Effettua l\'ordine',
    description: 'Seleziona i prodotti, personalizza le quantità e conferma l\'ordine con pagamento online o alla consegna. Semplice, intuitivo, veloce.',
  },
  {
    num: '3',
    emoji: '💬',
    title: 'Riceve aggiornamenti WhatsApp',
    description: 'Conferma ordine, stato di preparazione e notifica "pronto al ritiro" arrivano automaticamente su WhatsApp. Il cliente è sempre informato.',
  },
  {
    num: '4',
    emoji: '🎉',
    title: 'Ritira in store',
    description: 'Prodotto pronto, cliente già informato. Nessuna attesa inutile: arriva, ritira e se ne va soddisfatto.',
  },
];

const ristoratoreSteps = [
  {
    num: '1',
    emoji: '🔔',
    title: 'Riceve notifica',
    description: 'L\'ordine arriva in tempo reale sulla dashboard FoodBot. Conferma automatica o manuale: decidi tu il livello di controllo.',
  },
  {
    num: '2',
    emoji: '🔄',
    title: 'Logica Teglia ottimizza',
    description: 'FoodBot raggruppa automaticamente gli ordini per ottimizzare ogni teglia. 6-8 porzioni per cottura, zero sprechi, massima efficienza produttiva.',
  },
  {
    num: '3',
    emoji: '🖨️',
    title: 'Stampa automatica in laboratorio',
    description: 'L\'ordine viene stampato direttamente in laboratorio. Nessun passaggio manuale, nessun errore di trascrizione, produzione fluida.',
  },
  {
    num: '4',
    emoji: '✅',
    title: 'Notifica pronto al ritiro',
    description: 'Un tap e il cliente riceve la notifica WhatsApp "pronto al ritiro". Flusso completato, cliente soddisfatto, prossima teglia.',
  },
];

const automations = [
  {
    emoji: '⭐',
    title: 'Richiesta Recensione',
    desc: 'Dopo il ritiro, il cliente riceve un messaggio automatico con invito a lasciare una recensione. Più recensioni positive, più visibilità per la tua pizzeria.',
  },
  {
    emoji: '🎯',
    title: 'Comunicazioni Promo',
    desc: 'Offerte personalizzate, promozioni stagionali e sconti dedicati inviati automaticamente ai tuoi clienti. Fidelizzi senza sforzo.',
  },
  {
    emoji: '🔁',
    title: 'Reminder & Follow-up',
    desc: 'Re-engagement automatico dei clienti inattivi. FoodBot li riporta da te con messaggi mirati al momento giusto.',
  },
];

const setupSteps = [
  {
    num: '1',
    emoji: '📝',
    title: 'Registrazione',
    description: 'Crea il tuo account FoodBot in pochi click. Nessuna carta di credito richiesta, 30 giorni di prova gratuita.',
  },
  {
    num: '2',
    emoji: '🍕',
    title: 'Configura il menu',
    description: 'Carica i tuoi prodotti, imposta prezzi e varianti. L\'interfaccia guidata rende tutto semplice e immediato.',
  },
  {
    num: '3',
    emoji: '🚀',
    title: 'Inizia a ricevere ordini',
    description: 'Condividi il link del menu digitale con i tuoi clienti e inizia subito a ricevere ordini. Zero commissioni, zero pensieri.',
  },
];

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Come funziona FoodBot per la tua pizzeria al taglio",
  "description": "Scopri come FoodBot gestisce gli ordini da asporto della tua pizzeria al taglio in 4 step semplici, dall'ordine online al ritiro. Zero sprechi, zero commissioni.",
  "totalTime": "PT5M",
  "tool": [
    {
      "@type": "HowToTool",
      "name": "FoodBot — piattaforma Smart Takeaway Management"
    }
  ],
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Il cliente sceglie dal menu digitale",
      "text": "Il cliente apre il menu digitale della pizzeria al taglio dal proprio smartphone, senza scaricare app."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Effettua l'ordine online",
      "text": "Seleziona i prodotti, personalizza le quantità e conferma l'ordine con pagamento online o alla consegna."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Riceve aggiornamenti WhatsApp",
      "text": "Conferma ordine, stato di preparazione e notifica pronto al ritiro arrivano automaticamente su WhatsApp."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Ritira in store",
      "text": "Il cliente arriva in pizzeria, ritira l'ordine pronto senza attese inutili."
    },
    {
      "@type": "HowToStep",
      "position": 5,
      "name": "Registrazione a FoodBot",
      "text": "Crea il tuo account FoodBot in pochi click. Nessuna carta di credito richiesta, 30 giorni di prova gratuita."
    },
    {
      "@type": "HowToStep",
      "position": 6,
      "name": "Configura il menu digitale",
      "text": "Carica i tuoi prodotti, imposta prezzi e varianti con l'interfaccia guidata."
    },
    {
      "@type": "HowToStep",
      "position": 7,
      "name": "Inizia a ricevere ordini",
      "text": "Condividi il link del menu digitale e inizia a ricevere ordini. Zero commissioni sulle transazioni."
    }
  ]
};
---

<Layout
  title="Come Funziona FoodBot — Ordini Asporto per Pizzerie al Taglio in 4 Step"
  description="Scopri come FoodBot trasforma gli ordini da asporto della tua pizzeria al taglio. Dall'ordine online al ritiro: 4 step semplici, zero sprechi, zero commissioni."
>
  <Navbar />
  <Breadcrumb items={[{label: "Home", href: "/"}, {label: "Come Funziona"}]} />
  <main>
    <!-- Hero -->
    <section class="cf-hero section--dark">
      <div class="container" style="text-align:center;">
        <span class="section-label section-label--dark" style="justify-content:center;">Come Funziona</span>
        <h1 class="cf-hero__title">Come funziona <span style="color:var(--orange)">FoodBot</span></h1>
        <p class="cf-hero__subtitle">Dall'ordine online al ritiro in store: un flusso automatizzato che semplifica la vita al cliente e al ristoratore. Zero sprechi, zero commissioni.</p>
      </div>
      <div class="cf-hero__glow cf-hero__glow--orange"></div>
      <div class="cf-hero__glow cf-hero__glow--blue"></div>
    </section>

    <!-- Section 1: Per il Cliente -->
    <section class="cf-section section--dark" id="per-il-cliente" aria-labelledby="cf-cliente-title">
      <div class="container">
        <div class="section-intro reveal" style="text-align:center;margin-left:auto;margin-right:auto;">
          <span class="section-label section-label--dark" style="justify-content:center;">Lato Cliente</span>
          <h2 id="cf-cliente-title">Per il Cliente</h2>
          <p>Ordinare dalla tua pizzeria al taglio diventa semplice come un messaggio WhatsApp.</p>
        </div>

        <div class="cf-timeline">
          {clientSteps.map((s, i) => (
            <div class={`cf-step reveal reveal-delay-${i + 1}`}>
              <div class="cf-step__marker">
                <span class="cf-step__num">{s.num}</span>
                {i < clientSteps.length - 1 && <div class="cf-step__line"></div>}
              </div>
              <div class="cf-step__card">
                <span class="cf-step__emoji">{s.emoji}</span>
                <h3>{s.title}</h3>
                <p>{s.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 2: Per il Ristoratore -->
    <section class="cf-section cf-section--alt" id="per-il-ristoratore" aria-labelledby="cf-ristoratore-title">
      <div class="container">
        <div class="section-intro reveal" style="text-align:center;margin-left:auto;margin-right:auto;">
          <span class="section-label" style="justify-content:center;">Lato Ristoratore</span>
          <h2 id="cf-ristoratore-title">Per il Ristoratore</h2>
          <p>FoodBot gestisce il flusso di lavoro dalla notifica alla consegna, ottimizzando ogni teglia.</p>
        </div>

        <div class="cf-timeline">
          {ristoratoreSteps.map((s, i) => (
            <div class={`cf-step cf-step--light reveal reveal-delay-${i + 1}`}>
              <div class="cf-step__marker cf-step__marker--light">
                <span class="cf-step__num cf-step__num--light">{s.num}</span>
                {i < ristoratoreSteps.length - 1 && <div class="cf-step__line cf-step__line--light"></div>}
              </div>
              <div class="cf-step__card cf-step__card--light">
                <span class="cf-step__emoji">{s.emoji}</span>
                <h3>{s.title}</h3>
                <p>{s.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 3: Automazioni Post-Acquisto -->
    <section class="cf-section section--dark" id="automazioni" aria-labelledby="cf-automazioni-title">
      <div class="container">
        <div class="section-intro reveal" style="text-align:center;margin-left:auto;margin-right:auto;">
          <span class="section-label section-label--dark" style="justify-content:center;">Automazioni</span>
          <h2 id="cf-automazioni-title">Automazioni Post-Acquisto</h2>
          <p>Dopo il ritiro, FoodBot continua a lavorare per te. Fidelizza i clienti in automatico.</p>
        </div>

        <div class="cf-automations reveal">
          {automations.map((a, i) => (
            <div class={`cf-automation reveal reveal-delay-${i + 1}`}>
              <div class="cf-automation__icon">
                <span class="cf-automation__emoji">{a.emoji}</span>
              </div>
              <div class="cf-automation__content">
                <strong>{a.title}</strong>
                <p>{a.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="cf-automations-link reveal" style="text-align:center;margin-top:var(--space-xl);">
          <p style="color:rgba(255,255,255,0.6);">Scopri tutte le funzionalita nel dettaglio</p>
          <a href="/funzionalita" class="btn btn--secondary brand-orange" style="margin-top:var(--space-sm);">
            Vedi Funzionalita
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Section 4: Setup in 5 minuti -->
    <section class="cf-section cf-section--alt" id="setup" aria-labelledby="cf-setup-title">
      <div class="container">
        <div class="section-intro reveal" style="text-align:center;margin-left:auto;margin-right:auto;">
          <span class="section-label" style="justify-content:center;">Inizia Subito</span>
          <h2 id="cf-setup-title">Setup in <span style="color:var(--orange)">5 minuti</span></h2>
          <p>Nessuna installazione, nessun tecnico, nessuna complicazione. Tre step e sei operativo.</p>
        </div>

        <div class="cf-setup-grid">
          {setupSteps.map((s, i) => (
            <div class={`cf-setup-card reveal reveal-delay-${i + 1}`}>
              <div class="cf-setup-card__num">{s.num}</div>
              <span class="cf-setup-card__emoji">{s.emoji}</span>
              <h3>{s.title}</h3>
              <p>{s.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cf-cta section--dark" aria-labelledby="cf-cta-title">
      <div class="container" style="text-align:center;">
        <h2 id="cf-cta-title">Pronto a semplificare<br/>la tua pizzeria al taglio?</h2>
        <p style="max-width:560px;margin:var(--space-md) auto var(--space-lg);">Prova FoodBot gratis per 30 giorni. Nessuna carta di credito, nessuna commissione, nessun vincolo.</p>
        <div class="cf-cta__buttons">
          <a href="mailto:info@ristobot.it" class="btn btn--primary">
            Inizia la prova gratuita
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/prezzi" class="btn btn--secondary brand-orange">
            Vedi i prezzi
          </a>
        </div>
      </div>
      <div class="cf-hero__glow cf-hero__glow--orange" style="bottom:-100px;top:auto;"></div>
    </section>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
</Layout>

<style>
  /* ── Hero ── */
  .cf-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    background: var(--deep-dark);
    position: relative;
    overflow: hidden;
  }

  .cf-hero__title {
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
    font-weight: 900;
    color: var(--white);
    margin-bottom: var(--space-md);
  }

  .cf-hero__subtitle {
    max-width: 640px;
    margin: 0 auto;
    font-size: 1.15rem;
    color: rgba(255,255,255,0.65) !important;
    line-height: 1.7;
  }

  .cf-hero__glow {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(120px);
    opacity: 0.1;
  }

  .cf-hero__glow--orange {
    top: -50px;
    right: -100px;
    background: var(--orange);
  }

  .cf-hero__glow--blue {
    bottom: -100px;
    left: -100px;
    background: var(--teal);
    opacity: 0.08;
  }

  /* ── Sections ── */
  .cf-section {
    padding: var(--space-3xl) 0;
    position: relative;
    overflow: hidden;
  }

  .cf-section--alt {
    background: linear-gradient(180deg, #ffffff 0%, #f5f7fa 100%);
  }

  /* ── Timeline ── */
  .cf-timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    position: relative;
    z-index: 1;
  }

  .cf-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cf-step__marker {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    position: relative;
    margin-bottom: var(--space-md);
  }

  .cf-step__num {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--orange);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    background: rgba(255,107,53,0.1);
    border: 2px solid rgba(255,107,53,0.2);
  }

  .cf-step__num--light {
    background: rgba(255,107,53,0.08);
    border-color: rgba(255,107,53,0.2);
    color: var(--orange);
  }

  .cf-step__line {
    position: absolute;
    top: 50%;
    left: calc(50% + 32px);
    width: calc(100% - 32px);
    height: 2px;
    background: linear-gradient(90deg, var(--orange), var(--teal));
    z-index: 1;
    opacity: 0.4;
  }

  .cf-step__line--light {
    background: linear-gradient(90deg, var(--orange), var(--orange-light));
    opacity: 0.3;
  }

  .cf-step__card {
    padding: var(--space-lg);
    background: rgba(255,255,255,0.03);
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.1);
    width: 100%;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .cf-step__card:hover {
    background: rgba(255,255,255,0.055);
    border-color: rgba(255,255,255,0.18);
    box-shadow: 0 12px 32px rgba(0,0,0,0.2);
    transform: translateY(-4px);
  }

  .cf-step__card--light {
    background: var(--white);
    border: 1.5px solid rgba(0,0,0,0.06);
    box-shadow: var(--shadow-sm);
  }

  .cf-step__card--light:hover {
    background: var(--white);
    border-color: var(--orange);
    box-shadow: 0 12px 32px rgba(255,107,53,0.1);
    transform: translateY(-4px);
  }

  .cf-step__emoji {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-xs);
  }

  .cf-step__card h3 {
    margin-bottom: 0.5rem;
    font-size: 1.15rem;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--white);
  }

  .cf-step__card p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
  }

  /* Light variant overrides — must come AFTER base rules to win */
  .cf-step__card--light h3 {
    color: var(--dark);
  }

  .cf-step__card--light p {
    color: var(--gray-700);
  }

  /* ── Automations ── */
  .cf-automations {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    position: relative;
    z-index: 1;
  }

  .cf-automation {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: var(--space-lg);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    transition: all 0.4s ease;
  }

  .cf-automation:hover {
    background: rgba(255,255,255,0.055);
    border-color: rgba(255,255,255,0.18);
    box-shadow: 0 12px 32px rgba(0,0,0,0.2);
    transform: translateY(-4px);
  }

  .cf-automation__icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: rgba(255,107,53,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cf-automation__emoji {
    font-size: 1.6rem;
  }

  .cf-automation__content strong {
    color: var(--white);
    font-size: 1.05rem;
    font-family: var(--font-display);
    font-weight: 700;
    display: block;
    margin-bottom: 0.4rem;
  }

  .cf-automation__content p {
    color: rgba(255,255,255,0.55);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* ── Setup Grid ── */
  .cf-setup-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .cf-setup-card {
    background: var(--white);
    border: 1.5px solid rgba(0,0,0,0.06);
    border-radius: 24px;
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    position: relative;
  }

  .cf-setup-card:hover {
    transform: translateY(-6px);
    border-color: var(--orange);
    box-shadow: 0 20px 50px rgba(255,107,53,0.1);
  }

  .cf-setup-card__num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 900;
    color: rgba(255,107,53,0.85);
    line-height: 1;
    margin-bottom: var(--space-xs);
  }

  .cf-setup-card__emoji {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .cf-setup-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.6rem;
  }

  .cf-setup-card p {
    font-size: 0.92rem;
    color: var(--gray-700);
    line-height: 1.65;
  }

  /* ── CTA ── */
  .cf-cta {
    padding: var(--space-3xl) 0;
    position: relative;
    overflow: hidden;
  }

  .cf-cta h2 {
    color: var(--white);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .cf-cta__buttons {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .cf-timeline {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }

    .cf-step {
      flex-direction: row;
      text-align: left;
    }

    .cf-step__marker {
      width: auto;
      margin-bottom: 0;
      margin-right: var(--space-sm);
    }

    .cf-step__line {
      display: none;
    }

    .cf-step__card {
      padding: var(--space-md);
    }

    .cf-automations {
      grid-template-columns: 1fr;
    }

    .cf-setup-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }

  @media (max-width: 480px) {
    .cf-cta__buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
