    color: rgba(255, 255, 255, 0.3);
  }

  /* ── Article Section ── */
  .article-section {
    padding: var(--space-2xl) 0;
    background: var(--white);
  }

  /* ── Article Body ── */
  .article-body {
    font-family: var(--font-body);
    color: var(--gray-700);
    line-height: 1.8;
  }

