---
const steps = [
  {
    num: '01',
    emoji: '📱',
    title: 'Ordine Online',
    description: 'Il cliente effettua l\'ordine dalla piattaforma. Intuitivo, veloce, ottimizzato per mobile.',
  },
  {
    num: '02',
    emoji: '🔔',
    title: 'Notifica al Ristoratore',
    description: 'Conferma da webapp: automatica o manuale. Tu decidi il livello di controllo.',
  },
  {
    num: '03',
    emoji: '🔄',
    title: 'Aggiornamenti Live',
    description: 'Lo stato dell\'ordine si aggiorna in tempo reale. Il cliente sa sempre a che punto è la sua pizza.',
  },
  {
    num: '04',
    emoji: '🎉',
    title: 'Ritiro in Store',
    description: 'Prodotto pronto, cliente già informato. Esperienza fluida, nessuna attesa inutile.',
  },
];

const automations = [
  { emoji: '⭐', title: 'Richiesta Recensione', desc: 'Messaggio automatico dopo il ritiro' },
  { emoji: '🎯', title: 'Comunicazioni Promo', desc: 'Offerte personalizzate e stagionali' },
  { emoji: '🔁', title: 'Reminder & Follow-up', desc: 'Re-engagement clienti inattivi' },
];
---

<section class="come-funziona" id="come-funziona" aria-labelledby="come-funziona-title">
  <div class="container">
    <div class="section-intro reveal" style="text-align:center;margin-left:auto;margin-right:auto;">
      <span class="section-label" style="justify-content:center;">Come Funziona</span>
      <h2 id="come-funziona-title">Il cliente ordina online.<br/><span style="color:var(--orange)">FoodBot gestisce tutto il resto.</span></h2>
    </div>

    <div class="come-funziona__timeline">
      {steps.map((s, i) => (
        <div class={`come-funziona__step reveal reveal-delay-${i + 1}`}>
          <div class="come-funziona__step-marker">
            <span class="come-funziona__step-num">{s.num}</span>
            {i < steps.length - 1 && <div class="come-funziona__step-line"></div>}
          </div>
          <div class="come-funziona__step-card">
            <span class="come-funziona__step-emoji">{s.emoji}</span>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="come-funziona__automations reveal">
      <h3 class="come-funziona__automations-title">
        Automazioni Post-Acquisto
      </h3>
      <div class="come-funziona__automations-grid">
        {automations.map((a) => (
          <div class="come-funziona__automation">
            <div class="come-funziona__automation-icon">
              <span class="come-funziona__automation-emoji">{a.emoji}</span>
            </div>
            <div>
              <strong>{a.title}</strong>
              <p>{a.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="come-funziona__glow come-funziona__glow--orange"></div>
  <div class="come-funziona__glow come-funziona__glow--blue"></div>
</section>

<style>
  .come-funziona {
    background: #0D1B2A;
    padding: var(--space-3xl) 0;
    position: relative;
    overflow: hidden;
  }

  .come-funziona__glow {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(120px);
    opacity: 0.1;
  }

  .come-funziona__glow--orange {
    top: 0;
    right: -100px;
    background: #FF6B35;
  }

  .come-funziona__glow--blue {
    bottom: -100px;
    left: -100px;
    background: #4ECDC4;
    opacity: 0.08;
  }

  .come-funziona .section-intro h2 {
    color: var(--white);
  }

  .come-funziona .section-label {
    color: var(--orange);
  }

  .come-funziona__timeline {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    position: relative;
    z-index: 1;
  }

  .come-funziona__step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .come-funziona__step-marker {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: var(--space-md);
    width: 100%;
    justify-content: center;
    position: relative;
  }

  .come-funziona__step-num {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 900;
    color: #FF6B35;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    background: rgba(255,107,53,0.1);
    border: 2px solid rgba(255,107,53,0.2);
  }

  .come-funziona__step-line {
    position: absolute;
    top: 50%;
    left: calc(50% + 32px);
    width: calc(100% - 32px);
    height: 2px;
    background: linear-gradient(90deg, #FF6B35, #4ECDC4);
    z-index: 1;
    opacity: 0.4;
  }

  .come-funziona__step-card {
    padding: var(--space-lg);
    background: rgba(255,255,255,0.03);
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.1);
    width: 100%;
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .come-funziona__step-card:hover {
    background: rgba(255,255,255,0.055);
    border-color: rgba(255,255,255,0.18);
    box-shadow: 0 12px 32px rgba(0,0,0,0.2);
    transform: translateY(-4px);
  }

  .come-funziona__step-emoji {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-xs);
  }

  .come-funziona__step-card h3 {
    margin-bottom: 0.5rem;
    font-size: 1.15rem;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--white);
  }

  .come-funziona__step-card p {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
  }

  /* Automations bar */
  .come-funziona__automations {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    padding: var(--space-xl) var(--space-xl);
    position: relative;
    z-index: 1;
  }

  .come-funziona__automations-title {
    color: var(--white);
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: var(--space-md);
    text-align: center;
  }

  .come-funziona__automations-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .come-funziona__automation {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: var(--space-md);
    border-radius: 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    transition: all 0.3s ease;
  }

  .come-funziona__automation:hover {
    background: rgba(255,255,255,0.055);
    border-color: rgba(255,255,255,0.15);
  }

  .come-funziona__automation-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(255,107,53,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .come-funziona__automation-emoji {
    font-size: 1.4rem;
  }

  .come-funziona__automation strong {
    color: var(--white);
    font-size: 0.95rem;
    font-family: var(--font-display);
    font-weight: 700;
    display: block;
    margin-bottom: 0.2rem;
  }

  .come-funziona__automation p {
    color: rgba(255,255,255,0.55);
    font-size: 0.84rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .come-funziona__timeline {
      flex-direction: column;
    }

    .come-funziona__step-marker {
      justify-content: flex-start;
    }

    .come-funziona__step-line {
      display: none;
    }

    .come-funziona__step {
      flex-direction: row;
      text-align: left;
    }

    .come-funziona__step-card {
      padding: var(--space-md);
    }

    .come-funziona__automations-grid {
      grid-template-columns: 1fr;
    }

    .come-funziona__automations {
      padding: var(--space-md);
    }
  }
</style>
