---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const plans = [
  {
    name: 'Starter',
    subtitle: 'Per chi inizia',
    price: '49',
    period: '/mese',
    description: 'Perfetto per una singola pizzeria al taglio che vuole digitalizzare gli ordini da asporto.',
    features: [
      'Gestione ordini asporto',
      'Menu digitale personalizzabile',
      'Notifiche WhatsApp clienti',
      'Stampa ordini automatica',
      'Carta fedeltà digitale',
      'Supporto WhatsApp',
    ],
    cta: 'Prova gratis 30 giorni',
    highlighted: false,
  },
  {
    name: 'Professional',
    subtitle: 'Il più scelto',
    price: '89',
    period: '/mese',
    description: 'La soluzione completa per pizzerie al taglio che vogliono ottimizzare produzione e fidelizzare i clienti.',
    features: [
      'Tutto di Starter, più:',
      'Logica Teglia (ottimizzazione produzione)',
      'Sistema Upsell integrato',
      'Centralino Smart con redirect',
      'Automazioni post-acquisto',
      'Analytics vendite e clienti',
      'Supporto prioritario',
    ],
    cta: 'Prova gratis 30 giorni',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    subtitle: 'Multi punto vendita',
    price: 'Su misura',
    period: '',
    description: 'Per catene e pizzerie con più sedi. Gestione centralizzata, report aggregati e onboarding dedicato.',
    features: [
      'Tutto di Professional, più:',
      'Dashboard multi-sede',
      'Menu sincronizzati tra sedi',
      'Report per punto vendita',
      'Configurazione indipendente per sede',
      'Food Cost e marginalità',
      'Account manager dedicato',
      'Onboarding personalizzato',
    ],
    cta: 'Contattaci',
    highlighted: false,
  },
];

const faqs = [
  {
    q: 'Ci sono commissioni sugli ordini?',
    a: 'No, zero commissioni. Il canone mensile copre tutto: ordini illimitati, clienti illimitati, nessun costo nascosto.',
  },
  {
    q: 'Come funziona la prova gratuita?',
    a: 'Hai 30 giorni per provare FoodBot gratuitamente, senza inserire carta di credito. Al termine della prova, scegli il piano più adatto.',
  },
  {
    q: 'Posso cambiare piano in qualsiasi momento?',
    a: 'Sì, puoi fare upgrade o downgrade in qualsiasi momento. La differenza viene calcolata pro-rata.',
  },
  {
    q: 'C\'è uno sconto per il pagamento annuale?',
    a: 'Sì, con il pagamento annuale risparmi 2 mesi rispetto al canone mensile.',
  },
  {
    q: 'Cosa succede ai miei dati se disdico?',
    a: 'I tuoi dati restano disponibili per 90 giorni dopo la disdetta. Puoi esportarli in qualsiasi momento.',
  },
];

const pricingFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a,
    }
  }))
};
---

<Layout
  title="Prezzi FoodBot — Piani e Costi per Pizzerie al Taglio | Zero Commissioni"
  description="Scopri i piani FoodBot per la tua pizzeria al taglio. A partire da €49/mese, zero commissioni, prova gratis 30 giorni. Confronta Starter, Professional ed Enterprise."
>
  <Navbar />
  <Breadcrumb items={[{label: "Home", href: "/"}, {label: "Prezzi"}]} />
  <main>
    <section class="pricing-hero section--dark">
      <div class="container" style="text-align:center;">
        <span class="section-label section-label--dark" style="justify-content:center;">Prezzi</span>
        <h1 class="pricing-hero__title">Piani chiari.<br/><span style="color:var(--orange)">Zero commissioni.</span></h1>
        <p class="pricing-hero__subtitle">Canone fisso mensile o annuale. Nessun costo nascosto, nessuna commissione sulle transazioni. Prova gratis 30 giorni.</p>
      </div>
    </section>

    <section class="pricing-plans" aria-labelledby="pricing-plans-title">
      <h2 id="pricing-plans-title" class="sr-only">Piani e prezzi FoodBot</h2>
      <div class="container">
        <div class="pricing-plans__grid">
          {plans.map((plan) => (
            <div class={`pricing-card ${plan.highlighted ? 'pricing-card--highlighted' : ''}`}>
              {plan.highlighted && <div class="pricing-card__badge">Più scelto</div>}
              <div class="pricing-card__header">
                <h3>{plan.name}</h3>
                <span class="pricing-card__subtitle">{plan.subtitle}</span>
              </div>
              <div class="pricing-card__price">
                {plan.period ? (
                  <>
                    <span class="pricing-card__currency">€</span>
                    <span class="pricing-card__amount">{plan.price}</span>
                    <span class="pricing-card__period">{plan.period}</span>
                  </>
                ) : (
                  <span class="pricing-card__amount pricing-card__amount--custom">{plan.price}</span>
                )}
              </div>
              <p class="pricing-card__desc">{plan.description}</p>
              <ul class="pricing-card__features">
                {plan.features.map((f) => (
                  <li>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={plan.highlighted ? '#FF6B35' : '#2D8B4E'} stroke-width="2.5" stroke-linecap="round"><path d="M20 6 9 17l-5-5"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href={plan.name === 'Enterprise' ? 'mailto:info@ristobot.it' : '#contatti'} class={`pricing-card__cta ${plan.highlighted ? 'btn btn--primary' : 'btn btn--secondary brand-orange'}`}>
                {plan.cta}
              </a>
            </div>
          ))}
        </div>

        <div class="pricing-guarantees">
          <div class="pricing-guarantee">
            <strong>30 giorni gratis</strong>
            <p>Nessuna carta di credito richiesta</p>
          </div>
          <div class="pricing-guarantee">
            <strong>Zero commissioni</strong>
            <p>Ordini e clienti illimitati</p>
          </div>
          <div class="pricing-guarantee">
            <strong>Disdici quando vuoi</strong>
            <p>Nessun vincolo contrattuale</p>
          </div>
          <div class="pricing-guarantee">
            <strong>Setup in 5 minuti</strong>
            <p>Nessuna installazione richiesta</p>
          </div>
        </div>
      </div>
    </section>

    <section class="pricing-faq" aria-labelledby="pricing-faq-title">
      <div class="container container--narrow">
        <div class="section-intro" style="text-align:center;margin-left:auto;margin-right:auto;">
          <span class="section-label" style="justify-content:center;">Domande Frequenti</span>
          <h2 id="pricing-faq-title">Hai domande sui prezzi?</h2>
        </div>
        <div class="pricing-faq__list">
          {faqs.map((faq) => (
            <details class="pricing-faq__item">
              <summary>{faq.q}</summary>
              <p>{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="pricing-cta section--dark">
      <div class="container" style="text-align:center;">
        <h2>Pronto a iniziare?</h2>
        <p style="max-width:500px;margin:var(--space-md) auto var(--space-lg);">Prova FoodBot gratis per 30 giorni. Nessuna carta di credito, nessun vincolo.</p>
        <a href="mailto:info@ristobot.it" class="btn btn--primary">Scrivici: info@ristobot.it</a>
      </div>
    </section>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(pricingFaqSchema)} />
</Layout>

<style>
  .pricing-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    background: var(--deep-dark);
  }

  .pricing-hero__title {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 900;
    color: var(--white);
    margin-bottom: var(--space-md);
  }

  .pricing-hero__subtitle {
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.15rem;
    color: rgba(255,255,255,0.65) !important;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .pricing-plans {
    padding: var(--space-2xl) 0;
    background: linear-gradient(180deg, #ffffff 0%, #f5f7fa 100%);
  }

  .pricing-plans__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    align-items: start;
  }

  .pricing-card {
    background: var(--white);
    border-radius: 24px;
    padding: var(--space-xl) var(--space-lg);
    border: 1.5px solid rgba(0,0,0,0.06);
    transition: all 0.4s ease;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .pricing-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.08);
  }

  .pricing-card--highlighted {
    border-color: var(--orange);
    box-shadow: 0 12px 40px rgba(255,107,53,0.15);
    transform: scale(1.03);
  }

  .pricing-card--highlighted:hover {
    transform: scale(1.03) translateY(-6px);
    box-shadow: 0 24px 60px rgba(255,107,53,0.2);
  }

  .pricing-card__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: var(--white);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 1.2rem;
    border-radius: var(--radius-full);
    box-shadow: 0 4px 12px rgba(255,107,53,0.3);
  }

  .pricing-card__header h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.2rem;
  }

  .pricing-card__subtitle {
    font-size: 0.85rem;
    color: var(--gray-500);
    font-weight: 600;
  }

  .pricing-card__price {
    margin: var(--space-md) 0;
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
  }

  .pricing-card__currency {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--dark);
  }

  .pricing-card__amount {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--dark);
    line-height: 1;
  }

  .pricing-card__amount--custom {
    font-size: 2rem;
  }

  .pricing-card__period {
    font-size: 1rem;
    color: var(--gray-500);
    font-weight: 500;
  }

  .pricing-card__desc {
    font-size: 0.92rem;
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .pricing-card__features {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-bottom: var(--space-lg);
    flex: 1;
  }

  .pricing-card__features li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--gray-700);
  }

  .pricing-card__features svg {
    flex-shrink: 0;
  }

  .pricing-card__cta {
    width: 100%;
    justify-content: center;
    text-align: center;
  }

  .pricing-guarantees {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-2xl);
    padding: var(--space-lg);
    background: var(--white);
    border-radius: 24px;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
  }

  .pricing-guarantee {
    text-align: center;
  }

  .pricing-guarantee strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 0.25rem;
  }

  .pricing-guarantee p {
    font-size: 0.82rem;
    color: var(--gray-500);
  }

  /* FAQ */
  .pricing-faq {
    padding: var(--space-2xl) 0;
    background: var(--white);
  }

  .pricing-faq__list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .pricing-faq__item {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .pricing-faq__item:hover {
    border-color: var(--orange);
  }

  .pricing-faq__item[open] {
    border-color: var(--orange);
    box-shadow: 0 4px 16px rgba(255,107,53,0.08);
  }

  .pricing-faq__item summary {
    padding: var(--space-md) var(--space-lg);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--dark);
  }

  .pricing-faq__item summary::-webkit-details-marker { display: none; }

  .pricing-faq__item summary::after {
    content: '+';
    font-size: 1.4rem;
    color: var(--orange);
    font-weight: 300;
    transition: transform 0.3s ease;
  }

  .pricing-faq__item[open] summary::after {
    content: '−';
  }

  .pricing-faq__item p {
    padding: 0 var(--space-lg) var(--space-md);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* Bottom CTA */
  .pricing-cta {
    padding: var(--space-2xl) 0;
  }

  @media (max-width: 900px) {
    .pricing-plans__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }

    .pricing-card--highlighted {
      transform: none;
    }

    .pricing-guarantees {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .pricing-guarantees {
      grid-template-columns: 1fr;
    }
  }
</style>
