import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const blogPostSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "Come Gestire gli Ordini in una Pizzeria al Taglio: Guida Completa 2026",
  "description": "Scopri come gestire gli ordini nella tua pizzeria al taglio in modo efficiente. Guida pratica con 5 strategie per digitalizzare l'asporto e ridurre gli errori.",
  "datePublished": "2026-03-21",
  "author": {
    "@type": "Organization",
    "name": "FoodBot"
  },
  "publisher": {
    "@type": "Organization",
    "name": "FoodBot",
    "logo": {
      "@type": "ImageObject",
      "url": "https://ristobot.it/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://ristobot.it/blog/come-gestire-ordini-pizzeria-al-taglio"
  },
  "wordCount": 1000,
  "inLanguage": "it"
